@page "/trips/{Id:guid}"
@using ATP.Web.Features.Trips.Domain
@using ATP.Web.Features.Trips.Application
@using ATP.Web.Features.TravelPlans.Application
@using ATP.Web.Features.TravelPlans.Domain
@inject GetTrip GetTripUseCase
@inject ITravelPlanRepository TravelPlanRepository
@inject GenerateTravelPlan GenerateTravelPlanUseCase
@inject NavigationManager Navigation

<PageTitle>Detalhes da Viagem - AI Travel Planner</PageTitle>

<div class="trip-details">
    @if (_loading)
    {
        <div class="loading">
            <div class="loader-plane">✈</div>
            <span>Carregando detalhes da viagem...</span>
        </div>
    }
    else if (_trip is null)
    {
        <div class="empty-state">
            <div class="empty-illustration">
                <svg class="empty-map" viewBox="0 0 200 100" fill="none">
                    <circle cx="100" cy="50" r="35"
                            stroke="var(--color-border)" stroke-width="2.5"
                            stroke-dasharray="8 6" stroke-linecap="round" fill="none"/>
                    <circle cx="100" cy="50" r="4" fill="var(--color-primary)"
                            stroke="var(--color-primary-light)" stroke-width="2"/>
                    <line x1="72" y1="28" x2="128" y2="72"
                          stroke="var(--color-border)" stroke-width="2.5"
                          stroke-dasharray="6 4" stroke-linecap="round"/>
                </svg>
            </div>
            <p class="empty-title">Viagem não encontrada</p>
        </div>
    }
    else
    {
        <header class="detail-header">
            <div class="header-tag">
                <span class="header-initial">@(string.IsNullOrEmpty(_trip.Destination) ? '?' : _trip.Destination[0])</span>
            </div>
            <div class="header-body">
                <h1>@_trip.Destination, @_trip.Country</h1>
                <div class="trip-meta">
                    <span class="meta-item">
                        <span class="meta-icon">📅</span>
                        @_trip.StartDate.ToString("dd MMM") - @_trip.EndDate.ToString("dd MMM yyyy")
                    </span>
                    <span class="meta-item">
                        <span class="meta-icon">👤</span>
                        @_trip.NumberOfPeople pessoa@(_trip.NumberOfPeople > 1 ? "s" : "")
                    </span>
                    <span class="meta-item">
                        <span class="meta-icon">💰</span>
                        Orçamento: @_trip.Budget.ToString("C")
                    </span>
                </div>
            </div>
            <div class="header-actions">
                <button class="btn-secondary" @onclick="EditTrip">Editar</button>
            </div>
        </header>

        <section class="content-section">
            <h2><span class="section-icon">📌</span> Objetivos</h2>
            <p>@_trip.Objectives</p>
        </section>

        @if (!string.IsNullOrWhiteSpace(_trip.AdditionalNotes))
        {
            <section class="content-section">
                <h2><span class="section-icon">📎</span> Observações</h2>
                <p>@_trip.AdditionalNotes</p>
            </section>
        }

        <section class="plans-section">
            <div class="section-header">
                <h2><span class="section-icon">🗺</span> Planos de Viagem</h2>
                <button class="btn-primary" @onclick="GeneratePlan" disabled="@_generating" style="flex-shrink:0">
                    @(_generating ? "Gerando..." : "Gerar Plano")
                </button>
            </div>

            @if (_generating)
            {
                <div class="generating">
                    <span class="generating-dot"></span>
                    Gerando plano com IA...
                </div>
            }
            else if (_plans is { Count: 0 })
            {
                <div class="plans-empty">
                    <p>Nenhum plano gerado ainda.</p>
                    <p>Clique em "Gerar Plano" para criar seu roteiro personalizado.</p>
                </div>
            }
            else
            {
                <div class="plans-list">
                    @{
                        var planIdx = 0;
                    }
                    @foreach (var plan in _plans!)
                    {
                        <div class="plan-card @(plan.Status == PlanStatus.Failed ? "failed" : "")"
                             style="--i: @planIdx"
                             @onclick="() => ViewPlan(plan.Id)">
                            <div class="plan-stub">
                                <span class="plan-number">@(planIdx + 1)</span>
                            </div>
                            <div class="plan-body">
                                <div class="plan-top">
                                    <span class="status-badge status-@plan.Status.ToString().ToLower()">
                                        @(plan.Status switch
                                        {
                                            PlanStatus.Pending => "Pendente",
                                            PlanStatus.Processing => "Processando",
                                            PlanStatus.Completed => "Concluído",
                                            PlanStatus.Failed => "Falhou",
                                            _ => plan.Status.ToString()
                                        })
                                    </span>
                                </div>
                                <div class="plan-info">
                                    <span>@plan.GeneratedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                    @if (!string.IsNullOrEmpty(plan.Model))
                                    {
                                        <span class="plan-model">@plan.Model</span>
                                    }
                                </div>
                            </div>
                        </div>

                        planIdx++;
                    }
                </div>
            }
        </section>
    }
</div>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private Trip? _trip;
    private List<TravelPlan>? _plans;
    private bool _loading = true;
    private bool _generating;

    protected override async Task OnInitializedAsync()
    {
        _trip = await GetTripUseCase.ExecuteAsync(Id);
        if (_trip is not null)
        {
            _plans = await TravelPlanRepository.GetByTripAsync(Id);
        }
        _loading = false;
    }

    private void EditTrip()
    {
        Navigation.NavigateTo($"/trips/{Id}/edit");
    }

    private void ViewPlan(Guid planId)
    {
        Navigation.NavigateTo($"/trips/{Id}/plans/{planId}");
    }

    private async Task GeneratePlan()
    {
        _generating = true;
        var plan = await GenerateTravelPlanUseCase.ExecuteAsync(Id);
        _generating = false;

        if (plan is not null)
        {
            _plans = await TravelPlanRepository.GetByTripAsync(Id);
            StateHasChanged();
        }
    }
}
