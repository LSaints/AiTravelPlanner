@page "/trips/new"
@using ATP.Web.Features.Trips.Application
@using ATP.Web.Features.Trips.UI.Components
@using System.ComponentModel.DataAnnotations
@inject CreateTrip CreateTripUseCase
@inject NavigationManager Navigation

<PageTitle>Nova Viagem - AI Travel Planner</PageTitle>

<div class="new-trip">
    <div class="page-header">
        <h1><span class="page-icon">✈</span> Nova Viagem</h1>
    </div>

    <div class="form-card">
        <StepIndicator TotalSteps="3" CurrentStep="_currentStep" StepLabels="_stepLabels" />

        <EditForm EditContext="@_editContext" OnSubmit="@HandleSubmit" FormName="newTrip">
            <div class="step-content">
                @if (_currentStep == 0)
                {
                    <StepDestination @key="0" Model="@_trip" />
                }
                else if (_currentStep == 1)
                {
                    <StepBudget @key="1" Model="@_trip" />
                }
                else if (_currentStep == 2)
                {
                    <StepDetails @key="2" Model="@_trip" />
                }
            </div>

            <div class="form-actions">
                <button type="button" class="btn-secondary" @onclick="GoToPreviousStep" style="@(_currentStep > 0 ? "" : "display:none")">
                    Voltar
                </button>

                @if (_currentStep < 2)
                {
                    <button type="submit" class="btn-primary">
                        Próximo
                    </button>
                }
                else
                {
                    <button type="submit" class="btn-primary" disabled="@_saving">
                        @(_saving ? "Salvando..." : "Salvar Viagem")
                    </button>
                }

                <button type="button" class="btn-secondary" @onclick="Cancel">Cancelar</button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private TripFormModel _trip = new();
    private int _currentStep;
    private bool _saving;
    private EditContext _editContext = default!;
    private ValidationMessageStore _validationStore = default!;

    private readonly string[] _stepLabels = ["Destino", "Orçamento", "Detalhes"];

    private static readonly string[][] StepFields =
    [
        [nameof(TripFormModel.Destination), nameof(TripFormModel.Country), nameof(TripFormModel.StartDate), nameof(TripFormModel.EndDate)],
        [nameof(TripFormModel.NumberOfPeople), nameof(TripFormModel.Budget)],
        [nameof(TripFormModel.Objectives)]
    ];

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_trip);
        _validationStore = new ValidationMessageStore(_editContext);
    }

    private async Task HandleSubmit()
    {
        if (_currentStep < 2)
        {
            TryAdvanceStep();
        }
        else
        {
            await SubmitTrip();
        }
    }

    private void TryAdvanceStep()
    {
        var fields = StepFields[_currentStep];
        var isValid = true;

        foreach (var field in fields)
        {
            var fi = new FieldIdentifier(_trip, field);
            _validationStore.Clear(fi);

            var propInfo = typeof(TripFormModel).GetProperty(field)!;
            var value = propInfo.GetValue(_trip);
            var results = new List<ValidationResult>();
            var context = new ValidationContext(_trip) { MemberName = field };

            if (!Validator.TryValidateProperty(value, context, results))
            {
                isValid = false;
                foreach (var result in results)
                {
                    _validationStore.Add(fi, result.ErrorMessage ?? "Campo inválido");
                }
            }
        }

        _editContext.NotifyValidationStateChanged();

        if (isValid)
        {
            _currentStep++;
        }
    }

    private void GoToPreviousStep()
    {
        _validationStore.Clear();
        _editContext.NotifyValidationStateChanged();
        _currentStep--;
    }

    private async Task SubmitTrip()
    {
        var results = new List<ValidationResult>();
        var isValid = Validator.TryValidateObject(_trip, new ValidationContext(_trip), results, true);

        _validationStore.Clear();

        if (!isValid)
        {
            foreach (var result in results)
            {
                foreach (var memberName in result.MemberNames)
                {
                    _validationStore.Add(new FieldIdentifier(_trip, memberName), result.ErrorMessage ?? "Campo inválido");
                }
            }
            _editContext.NotifyValidationStateChanged();
            return;
        }

        _saving = true;

        var request = new CreateTripRequest(
            _trip.Destination,
            _trip.Country,
            _trip.StartDate,
            _trip.EndDate,
            _trip.NumberOfPeople,
            _trip.Budget,
            _trip.Objectives,
            _trip.AdditionalNotes
        );

        var trip = await CreateTripUseCase.ExecuteAsync(request);
        _saving = false;

        Navigation.NavigateTo($"/trips/{trip.Id}");
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/");
    }
}
