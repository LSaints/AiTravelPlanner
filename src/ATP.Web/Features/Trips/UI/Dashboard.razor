@page "/"
@using ATP.Web.Features.Trips.Application
@using ATP.Web.Features.Trips.Domain
@inject ITripRepository TripRepository
@inject NavigationManager Navigation

<PageTitle>Dashboard - AI Travel Planner</PageTitle>

<div class="dashboard">
    <header class="dashboard-header">
        <div class="dashboard-title">
            <h1>Minhas Viagens</h1>
            @if (_trips is { Count: > 0 })
            {
                <span class="trip-count">@_trips.Count viagem@(_trips.Count > 1 ? "ns" : "")</span>
            }
        </div>
        <button class="new-trip-btn" @onclick="NavigateToNewTrip">
            <span class="btn-icon">✈</span>
            Nova Viagem
        </button>
    </header>

    @if (_loading)
    {
        <div class="loading">
            <div class="loader-plane">✈</div>
            <span>Carregando suas viagens...</span>
        </div>
    }
    else if (_trips is { Count: 0 })
    {
        <div class="empty-state">
            <div class="empty-illustration">
                <svg class="empty-map" viewBox="0 0 240 120" fill="none">
                    <path d="M30 60 Q80 20 120 60 T210 60"
                          stroke="var(--color-border)" stroke-width="2.5"
                          stroke-dasharray="8 6" stroke-linecap="round"/>
                    <circle cx="30" cy="60" r="8" fill="var(--color-primary)"
                            stroke="var(--color-primary-light)" stroke-width="2.5"/>
                    <circle cx="120" cy="60" r="5" fill="var(--color-bg-elevated)"
                            stroke="var(--color-border)" stroke-width="2"/>
                    <circle cx="210" cy="60" r="8" fill="var(--color-primary)"
                            stroke="var(--color-primary-light)" stroke-width="2.5"/>
                </svg>
            </div>
            <p class="empty-title">Nenhuma viagem ainda</p>
            <p class="empty-subtitle">Sua próxima aventura espera por você!</p>
            <button class="new-trip-btn empty-cta" @onclick="NavigateToNewTrip">
                <span class="btn-icon">✈</span>
                Criar Primeira Viagem
            </button>
        </div>
    }
    else
    {
        <div class="trip-list">
            @{
                var cardIdx = 0;
            }
            @foreach (var trip in _trips!)
            {
                var duration = trip.EndDate.DayNumber - trip.StartDate.DayNumber;
                var initial = string.IsNullOrEmpty(trip.Destination) ? '?' : trip.Destination[0];

                <div class="trip-card" style="--i: @cardIdx" @onclick="() => NavigateToTrip(trip.Id)">
                    <div class="card-tag">
                        <span class="card-initial">@initial</span>
                    </div>
                    <div class="card-body">
                        <div class="card-top">
                            <h3>@trip.Destination, @trip.Country</h3>
                            <span class="card-duration">@duration @(duration == 1 ? "dia" : "dias")</span>
                        </div>
                        <div class="card-meta">
                            <span class="card-dates">
                                <span class="meta-icon">📅</span>
                                @trip.StartDate.ToString("dd MMM") - @trip.EndDate.ToString("dd MMM yyyy")
                            </span>
                            <span class="card-people">
                                <span class="meta-icon">👤</span>
                                @trip.NumberOfPeople @(trip.NumberOfPeople > 1 ? "pessoas" : "pessoa")
                            </span>
                        </div>
                        <div class="card-budget">
                            <span class="budget-label">Orçamento</span>
                            <span class="budget-value">@trip.Budget.ToString("C")</span>
                        </div>
                    </div>
                </div>

                cardIdx++;
            }
        </div>
    }
</div>

@code {
    private List<Trip>? _trips;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _trips = await TripRepository.GetAllAsync();
        _loading = false;
    }

    private void NavigateToNewTrip()
    {
        Navigation.NavigateTo("/trips/new");
    }

    private void NavigateToTrip(Guid id)
    {
        Navigation.NavigateTo($"/trips/{id}");
    }
}
